+import { getModelEntry } from "../../bare/registry/model-registry.js";
+import { getRPC } from "../../bare/delegate-rpc-client.js";
+import { stream } from "../delegate-transport.js";
+import { ModelIsDelegatedError } from "../../../utils/errors-server.js";
+import { getServerLogger } from "../../../logging/index.js";
+const logger = getServerLogger();
+export async function* handleDiffusionStreamDelegated(request, options) {
+    const { profilingMeta } = options ?? {};
+    const entry = getModelEntry(request.modelId);
+    if (!entry?.isDelegated) {
+        throw new ModelIsDelegatedError(request.modelId);
+    }
+    const { providerPublicKey, timeout, healthCheckTimeout } = entry.delegated;
+    logger.debug(`📤 Sending delegated diffusion request to provider: ${providerPublicKey}${timeout ? `, timeout: ${timeout}ms` : ""}`);
+    const rpc = await getRPC(providerPublicKey, { timeout, healthCheckTimeout });
+    const delegateOpts = { peerKey: providerPublicKey };
+    if (profilingMeta) {
+        delegateOpts.profilingMeta = profilingMeta;
+    }
+    if (timeout) {
+        delegateOpts.timeout = timeout;
+    }
+    const responseStream = stream(request, rpc, delegateOpts);
+    for await (const response of responseStream) {
+        yield response;
+    }
+}
