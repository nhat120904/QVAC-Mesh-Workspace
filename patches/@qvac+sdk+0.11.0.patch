index 0000000..e5a9b9f
--- /dev/null
+++ b/node_modules/@qvac/sdk/dist/server/rpc/handlers/transcribe-delegated.js
@@ -0,0 +1,52 @@
+import { getModelEntry } from "../../bare/registry/model-registry.js";
+import { getRPC } from "../../bare/delegate-rpc-client.js";
+import { stream } from "../delegate-transport.js";
+import { ModelIsDelegatedError } from "../../../utils/errors-server.js";
+import { getServerLogger } from "../../../logging/index.js";
+const logger = getServerLogger();
+export async function* handleTranscribeDelegated(request, options) {
+    const { profilingMeta } = options ?? {};
+    const entry = getModelEntry(request.modelId);
+    if (!entry?.isDelegated) {
+        throw new ModelIsDelegatedError(request.modelId);
+    }
+    const { providerPublicKey, timeout, healthCheckTimeout } = entry.delegated;
+    logger.debug(`📤 Sending delegated transcribe request to provider: ${providerPublicKey}${timeout ? `, timeout: ${timeout}ms` : ""}`);
+
+    // Inline local audio file paths into base64 so the provider does not need access to caller's filesystem.
+    async function inlineAudioChunk(obj) {
+        if (obj == null)
+            return obj;
+        if (Array.isArray(obj)) return Promise.all(obj.map(inlineAudioChunk));
+        if (typeof obj === "object") {
+            if (obj.type === "filePath" && typeof obj.value === "string") {
+                try {
+                    if (typeof process !== "undefined" && process?.versions?.node) {
+                        const fs = await import("node:fs/promises");
+                        const data = await fs.readFile(obj.value);
+                        return { type: "base64", value: data.toString("base64") };
+                    }
+                }
+                catch (err) {
+                    // If reading fails, rethrow so upstream will surface AUDIO_FILE_NOT_FOUND
+                    throw err;
+                }
+            }
+            const out = {};
+            for (const [k, v] of Object.entries(obj)) {
+                out[k] = await inlineAudioChunk(v);
+            }
+            return out;
+        }
+        return obj;
+    }
+
+    const safeRequest = await inlineAudioChunk(request);
+    const rpc = await getRPC(providerPublicKey, { timeout, healthCheckTimeout });
+    const delegateOpts = { peerKey: providerPublicKey };
+    if (profilingMeta) {
+        delegateOpts.profilingMeta = profilingMeta;
+    }
+    if (timeout) {
+        delegateOpts.timeout = timeout;
+    }
+    const responseStream = stream(safeRequest, rpc, delegateOpts);
+    for await (const response of responseStream) {
+        yield response;
+    }
+}
